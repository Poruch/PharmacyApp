<UserControl x:Class="PharmacyApp.Controls.PharmacistControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BrushBackground}">
    <TabControl Style="{StaticResource MainTabControl}" Margin="4">
        <TabItem Header="Приёмка" Style="{StaticResource InnerTabItem}">
            <Border Style="{StaticResource CardBorder}" Margin="8" MaxWidth="480" HorizontalAlignment="Left">
                <StackPanel>
                    <TextBlock Text="Накладная" Style="{StaticResource MutedCaption}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding InvoiceScanCode}" Margin="0,0,0,8"/>
                    <Button Content="Найти поставщика" Command="{Binding FindSupplierByInvoiceCommand}"
                            Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Поставщик: " Style="{StaticResource MutedCaption}"/>
                        <TextBlock Text="{Binding FoundSupplierName}" FontWeight="SemiBold"/>
                    </StackPanel>
                    <Button Content="Приёмка партии" Command="{Binding SaveBatchAndItemsCommand}"
                            Style="{StaticResource PrimaryButton}" HorizontalContentAlignment="Left"/>
                </StackPanel>
            </Border>
        </TabItem>

        <TabItem Header="Склад" Style="{StaticResource InnerTabItem}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                <StackPanel MaxWidth="720">
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="Перемещение партии" Style="{StaticResource SectionTitle}"/>
                            <TextBlock Text="Партия" Style="{StaticResource MutedCaption}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding Batches}" DisplayMemberPath="SerialNumber"
                                      SelectedItem="{Binding SelectedBatch}" Margin="0,0,0,8"/>
                            <TextBlock Text="Новое место" Style="{StaticResource MutedCaption}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding StorageLocations}" DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding SelectedNewStorageLocation}" Margin="0,0,0,8"/>
                            <Button Content="Переместить" Command="{Binding MoveBatchCommand}"
                                    Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"/>
                            <TextBlock Text="{Binding SelectedBatchStorageConditions}" TextWrapping="Wrap"
                                       Style="{StaticResource MutedCaption}" Margin="0,12,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Учёт" Style="{StaticResource InnerTabItem}">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,6,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Инвентаризация" Style="{StaticResource SectionTitle}"/>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding InventoryItems}" AutoGenerateColumns="False" MinHeight="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Товар" Binding="{Binding ItemName}" Width="*"/>
                                <DataGridTextColumn Header="Серия" Binding="{Binding BatchNumber}" Width="70"/>
                                <DataGridTextColumn Header="Учёт" Binding="{Binding AccountQuantity}" Width="50" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Факт" Binding="{Binding ActualQuantity, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Button Grid.Row="2" Content="Применить" Command="{Binding CompareAndCorrectCommand}"
                                Style="{StaticResource WarningButton}" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="6,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Списание" Style="{StaticResource SectionTitle}" Margin="0,0,6,12"/>
                            <TextBlock Text="{Binding ExpiredBatchesCount, StringFormat='({0})'}"
                                       Style="{StaticResource MutedCaption}" VerticalAlignment="Top" Margin="0,4,0,0"/>
                        </StackPanel>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding ExpiredBatches}" AutoGenerateColumns="False" MinHeight="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Товар" Binding="{Binding ItemName}" Width="*"/>
                                <DataGridTextColumn Header="Срок" Binding="{Binding ExpiryDate, StringFormat=dd.MM.yy}" Width="70"/>
                                <DataGridTextColumn Header="Кол." Binding="{Binding Quantity}" Width="45"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Обновить" Command="{Binding RefreshExpiredCommand}"
                                    Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                            <Button Content="Списать" Command="{Binding CreateWriteOffDocCommand}"
                                    Style="{StaticResource DangerButton}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </TabItem>
    </TabControl>
</UserControl>
