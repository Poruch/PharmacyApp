<UserControl x:Class="PharmacyApp.Controls.CashierControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BrushBackground}">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,8" Padding="12">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ShiftStatusText}" FontWeight="SemiBold" Foreground="{StaticResource BrushPrimary}" Margin="0,0,16,0"/>
                    <TextBlock Text="{Binding CurrentUser}" Style="{StaticResource MutedCaption}" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Открыть смену" Command="{Binding OpenShiftCommand}" Style="{StaticResource AccentButton}" Margin="0,0,8,0" Padding="12,6"/>
                    <Button Content="Закрыть смену" Command="{Binding CloseShiftCommand}" Style="{StaticResource DangerButton}" Padding="12,6"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Style="{StaticResource MainTabControl}">
            <TabItem Header="Продажа" Style="{StaticResource InnerTabItem}">
                <Border Style="{StaticResource CardBorder}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding Barcode, UpdateSourceTrigger=PropertyChanged}" Padding="8"
                                     ToolTip="Штрихкод, Enter">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding ScanBarcodeCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="1" Content="Вручную" Command="{Binding AddItemManuallyCommand}"
                                    Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Padding="12,6"/>
                        </Grid>
                        <CheckBox Grid.Row="1" Content="Рецепт проверен" IsChecked="{Binding PrescriptionVerified}"
                                  IsEnabled="{Binding IsPrescriptionRequired}" Margin="0,0,0,8"/>

                        <DataGrid Grid.Row="2" ItemsSource="{Binding Cart}" AutoGenerateColumns="False" MinHeight="160">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Товар" Binding="{Binding ItemName}" Width="*"/>
                                <DataGridTextColumn Header="Кол." Binding="{Binding Quantity}" Width="50"/>
                                <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat=C}" Width="80"/>
                                <DataGridTextColumn Header="Сумма" Binding="{Binding Total, StringFormat=C}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8">
                            <TextBlock Text="Итого: " VerticalAlignment="Center" FontSize="16"/>
                            <TextBlock Text="{Binding CartTotal, StringFormat=C}" FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource BrushPrimary}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <UniformGrid Grid.Row="4" Columns="2" Margin="0,4,0,0">
                            <Button Content="Наличные" Command="{Binding PayCashCommand}" Style="{StaticResource AccentButton}" Margin="0,0,4,0"/>
                            <Button Content="Карта" Command="{Binding PayCardCommand}" Style="{StaticResource PrimaryButton}" Margin="4,0,0,0"/>
                        </UniformGrid>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Header="Возврат" Style="{StaticResource InnerTabItem}">
                <Border Style="{StaticResource CardBorder}" MaxWidth="420" HorizontalAlignment="Left">
                    <StackPanel>
                        <TextBlock Text="Номер чека" Style="{StaticResource MutedCaption}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding ReturnReceiptNumber}" Margin="0,0,0,12"/>
                        <Button Content="Оформить возврат" Command="{Binding ProcessReturnCommand}"
                                Style="{StaticResource WarningButton}" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <TabItem Header="Смена" Style="{StaticResource InnerTabItem}">
                <Border Style="{StaticResource CardBorder}" MaxWidth="360" HorizontalAlignment="Left">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Начало" Style="{StaticResource MutedCaption}"/>
                        <TextBlock Grid.Column="1" Text="{Binding ShiftStartTime, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"/>
                        <TextBlock Grid.Row="1" Text="Чеков" Style="{StaticResource MutedCaption}"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ShiftSalesCount}"/>
                        <TextBlock Grid.Row="2" Text="Наличные" Style="{StaticResource MutedCaption}"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ShiftTotalCash, StringFormat=C}"/>
                        <TextBlock Grid.Row="3" Text="Карта" Style="{StaticResource MutedCaption}"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ShiftTotalCard, StringFormat=C}"/>
                        <TextBlock Grid.Row="4" Text="Всего" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ShiftTotal, StringFormat=C}" FontWeight="Bold" Foreground="{StaticResource BrushPrimary}"/>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
