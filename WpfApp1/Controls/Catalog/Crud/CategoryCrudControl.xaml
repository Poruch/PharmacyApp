<UserControl x:Class="PharmacyApp.Controls.Crud.CategoryCrudControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="GridCategories" Grid.Row="0" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" SelectionChanged="GridCategories_SelectionChanged" MinHeight="160" Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*"/>
                <DataGridTextColumn Header="Родитель" Binding="{Binding ParentName}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="1" Style="{StaticResource CardBorder}">
            <StackPanel>
            <TextBlock Text="Редактирование" Style="{StaticResource SectionTitle}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Название *" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtName" Grid.Column="1" Margin="0,4" Padding="6"/>
                <TextBlock Grid.Row="1" Text="Описание" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtDescription" Grid.Row="1" Grid.Column="1" Margin="0,4" Padding="6"/>
                <TextBlock Grid.Row="2" Text="Родитель" VerticalAlignment="Center"/>
                <ComboBox x:Name="CmbParent" Grid.Row="2" Grid.Column="1" DisplayMemberPath="Name"
                          Margin="0,4" Padding="4" IsEditable="False"/>
            </Grid>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Обновить" Click="BtnRefresh_Click" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
            <Button Content="Новая" Click="BtnNew_Click" Style="{StaticResource OutlineButton}" Margin="0,0,8,0"/>
            <Button Content="Сохранить" Click="BtnSave_Click" Style="{StaticResource AccentButton}" Margin="0,0,8,0"/>
            <Button Content="Удалить" Click="BtnDelete_Click" Style="{StaticResource DangerButton}"/>
        </StackPanel>
    </Grid>
</UserControl>
