<UserControl x:Class="PharmacyApp.Controls.Crud.SupplierCrudControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="GridSuppliers" Grid.Row="0" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" SelectionChanged="GridSuppliers_SelectionChanged" MinHeight="160" Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="ИНН" Binding="{Binding Inn}" Width="120"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <GroupBox Grid.Row="1" Header="Поставщик" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Название *" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtName" Grid.Column="1" Margin="0,4" Padding="6"/>
                <TextBlock Grid.Row="1" Text="ИНН" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtInn" Grid.Row="1" Grid.Column="1" Margin="0,4" Padding="6"/>
                <TextBlock Grid.Row="2" Text="Телефон" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtPhone" Grid.Row="2" Grid.Column="1" Margin="0,4" Padding="6"/>
                <TextBlock Grid.Row="3" Text="Email" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtEmail" Grid.Row="3" Grid.Column="1" Margin="0,4" Padding="6"/>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Обновить" Click="BtnRefresh_Click" Margin="0,0,8,0" Padding="12,6"/>
            <Button Content="Новый" Click="BtnNew_Click" Margin="0,0,8,0" Padding="12,6"/>
            <Button Content="Сохранить" Click="BtnSave_Click" Background="#28A745" Foreground="White" Margin="0,0,8,0" Padding="12,6"/>
            <Button Content="Удалить" Click="BtnDelete_Click" Background="#DC3545" Foreground="White" Padding="12,6"/>
        </StackPanel>
    </Grid>
</UserControl>
