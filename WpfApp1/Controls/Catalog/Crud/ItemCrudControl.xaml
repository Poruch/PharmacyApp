<UserControl x:Class="PharmacyApp.Controls.Crud.ItemCrudControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="GridItems" Grid.Row="0" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" SelectionChanged="GridItems_SelectionChanged" MinHeight="140" Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="45"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Штрихкод" Binding="{Binding Barcode}" Width="110"/>
                <DataGridTextColumn Header="Категория" Binding="{Binding CategoryName}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="280" Margin="0,0,0,10">
            <GroupBox Header="Товар" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Название *" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtName" Grid.Column="1" Margin="0,4" Padding="6"/>
                    <TextBlock Grid.Column="2" Text="Штрихкод" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <TextBox x:Name="TxtBarcode" Grid.Column="3" Margin="0,4" Padding="6"/>

                    <TextBlock Grid.Row="1" Text="МНН" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtInn" Grid.Row="1" Grid.Column="1" Margin="0,4" Padding="6"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Категория *" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <ComboBox x:Name="CmbCategory" Grid.Row="1" Grid.Column="3" DisplayMemberPath="Name" Margin="0,4" Padding="4"/>

                    <TextBlock Grid.Row="2" Text="Дозировка" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtDosage" Grid.Row="2" Grid.Column="1" Margin="0,4" Padding="6"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="Форма" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <TextBox x:Name="TxtForm" Grid.Row="2" Grid.Column="3" Margin="0,4" Padding="6"/>

                    <TextBlock Grid.Row="3" Text="Ед. изм. *" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtUnit" Grid.Row="3" Grid.Column="1" Margin="0,4" Padding="6" Text="таб."/>
                    <TextBlock Grid.Row="3" Grid.Column="2" Text="В упаковке *" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <TextBox x:Name="TxtPack" Grid.Row="3" Grid.Column="3" Margin="0,4" Padding="6" Text="1"/>

                    <TextBlock Grid.Row="4" Text="Мин. остаток" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtMinStock" Grid.Row="4" Grid.Column="1" Margin="0,4" Padding="6" Text="5"/>
                    <StackPanel Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="8,4,0,0">
                        <CheckBox x:Name="ChkRx" Content="Рецептурный" Margin="0,0,16,0"/>
                        <CheckBox x:Name="ChkVital" Content="ЖНВЛП"/>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Обновить" Click="BtnRefresh_Click" Margin="0,0,8,0" Padding="12,6"/>
            <Button Content="Новый" Click="BtnNew_Click" Margin="0,0,8,0" Padding="12,6"/>
            <Button Content="Сохранить" Click="BtnSave_Click" Background="#28A745" Foreground="White" Margin="0,0,8,0" Padding="12,6"/>
            <Button Content="Удалить" Click="BtnDelete_Click" Background="#DC3545" Foreground="White" Padding="12,6"/>
        </StackPanel>
    </Grid>
</UserControl>
