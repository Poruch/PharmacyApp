<UserControl x:Class="PharmacyApp.Controls.EntityManagementControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:crud="clr-namespace:PharmacyApp.Controls.Crud"
             Background="{StaticResource BrushBackground}">
    <TabControl Style="{StaticResource MainTabControl}" Margin="4">
        <TabItem Header="Категории" Style="{StaticResource InnerTabItem}">
            <crud:CategoryCrudControl/>
        </TabItem>
        <TabItem Header="Товары" Style="{StaticResource InnerTabItem}">
            <crud:ItemCrudControl/>
        </TabItem>
        <TabItem Header="Поставщики" Style="{StaticResource InnerTabItem}">
            <crud:SupplierCrudControl/>
        </TabItem>
        <TabItem Header="Места хранения" Style="{StaticResource InnerTabItem}">
            <crud:StorageLocationCrudControl/>
        </TabItem>
        <TabItem Header="Партии" Style="{StaticResource InnerTabItem}">
            <crud:BatchCrudControl/>
        </TabItem>
    </TabControl>
</UserControl>
