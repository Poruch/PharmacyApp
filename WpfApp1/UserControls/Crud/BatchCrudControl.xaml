<UserControl x:Class="PharmacyApp.Controls.Crud.BatchCrudControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="GridBatches" Grid.Row="0" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" SelectionChanged="GridBatches_SelectionChanged" MinHeight="140" Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="45"/>
                <DataGridTextColumn Header="Серия" Binding="{Binding BatchNumber}" Width="90"/>
                <DataGridTextColumn Header="Товар" Binding="{Binding ItemName}" Width="*"/>
                <DataGridTextColumn Header="Поставщик" Binding="{Binding SupplierName}" Width="*"/>
                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="60"/>
                <DataGridTextColumn Header="Розн." Binding="{Binding RetailPrice, StringFormat=N2}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="300" Margin="0,0,0,10">
            <GroupBox Header="Партия" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Номер серии *" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtBatchNumber" Grid.Column="1" Margin="0,4" Padding="6"/>
                    <TextBlock Grid.Column="2" Text="Количество *" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <TextBox x:Name="TxtQuantity" Grid.Column="3" Margin="0,4" Padding="6"/>

                    <TextBlock Grid.Row="1" Text="Товар *" VerticalAlignment="Center"/>
                    <ComboBox x:Name="CmbItem" Grid.Row="1" Grid.Column="1" DisplayMemberPath="Name" Margin="0,4" Padding="4"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Поставщик *" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <ComboBox x:Name="CmbSupplier" Grid.Row="1" Grid.Column="3" DisplayMemberPath="Name" Margin="0,4" Padding="4"/>

                    <TextBlock Grid.Row="2" Text="Закупочная *" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtPurchase" Grid.Row="2" Grid.Column="1" Margin="0,4" Padding="6"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="Розничная *" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <TextBox x:Name="TxtRetail" Grid.Row="2" Grid.Column="3" Margin="0,4" Padding="6"/>

                    <TextBlock Grid.Row="3" Text="Срок годности" VerticalAlignment="Center"/>
                    <DatePicker x:Name="DpExpiry" Grid.Row="3" Grid.Column="1" Margin="0,4"/>
                    <TextBlock Grid.Row="3" Grid.Column="2" Text="Место хранения" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <TextBox x:Name="TxtStorage" Grid.Row="3" Grid.Column="3" Margin="0,4" Padding="6"/>

                    <TextBlock Grid.Row="4" Text="Дата производства" VerticalAlignment="Center"/>
                    <DatePicker x:Name="DpProduction" Grid.Row="4" Grid.Column="1" Margin="0,4"/>
                </Grid>
            </GroupBox>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Обновить" Click="BtnRefresh_Click" Margin="0,0,8,0" Padding="12,6"/>
            <Button Content="Новая" Click="BtnNew_Click" Margin="0,0,8,0" Padding="12,6"/>
            <Button Content="Сохранить" Click="BtnSave_Click" Background="#28A745" Foreground="White" Margin="0,0,8,0" Padding="12,6"/>
            <Button Content="Удалить" Click="BtnDelete_Click" Background="#DC3545" Foreground="White" Padding="12,6"/>
        </StackPanel>
    </Grid>
</UserControl>
