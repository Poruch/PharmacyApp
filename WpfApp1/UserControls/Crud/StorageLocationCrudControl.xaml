<UserControl x:Class="PharmacyApp.Controls.Crud.StorageLocationCrudControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="GridLocations" Grid.Row="0" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" SelectionChanged="GridLocations_SelectionChanged"
                  MinHeight="160" Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding LocationId}" Width="50"/>
                <DataGridTextColumn Header="Стеллаж / зона" Binding="{Binding Shelf}" Width="*"/>
                <DataGridTextColumn Header="Ячейка" Binding="{Binding Cell}" Width="120"/>
                <DataGridTextColumn Header="Отображение" Binding="{Binding DisplayName}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <GroupBox Grid.Row="1" Header="Место хранения" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Стеллаж / зона *" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtShelf" Grid.Column="1" Margin="0,4" Padding="6"/>
                <TextBlock Grid.Row="1" Text="Ячейка / полка" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtCell" Grid.Row="1" Grid.Column="1" Margin="0,4" Padding="6"/>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Обновить" Click="BtnRefresh_Click" Margin="0,0,8,0" Padding="12,6"/>
            <Button Content="Новое" Click="BtnNew_Click" Margin="0,0,8,0" Padding="12,6"/>
            <Button Content="Сохранить" Click="BtnSave_Click" Background="#28A745" Foreground="White" Margin="0,0,8,0" Padding="12,6"/>
            <Button Content="Удалить" Click="BtnDelete_Click" Background="#DC3545" Foreground="White" Padding="12,6"/>
        </StackPanel>
    </Grid>
</UserControl>
