<UserControl x:Class="PharmacyApp.Controls.EntityManagementControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:crud="clr-namespace:PharmacyApp.Controls.Crud"
             Background="{StaticResource BrushBackground}">
    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource BrushCard}" CornerRadius="10" Padding="16,12"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="Справочники" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B"/>
                <TextBlock Text="Управление категориями, товарами, поставщиками, местами хранения и партиями"
                           Style="{StaticResource MutedCaption}" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" Style="{StaticResource MainTabControl}">
            <TabItem Header="Категории" Style="{StaticResource InnerTabItem}">
                <crud:CategoryCrudControl/>
            </TabItem>
            <TabItem Header="Товары" Style="{StaticResource InnerTabItem}">
                <crud:ItemCrudControl/>
            </TabItem>
            <TabItem Header="Поставщики" Style="{StaticResource InnerTabItem}">
                <crud:SupplierCrudControl/>
            </TabItem>
            <TabItem Header="Места хранения" Style="{StaticResource InnerTabItem}">
                <crud:StorageLocationCrudControl/>
            </TabItem>
            <TabItem Header="Партии" Style="{StaticResource InnerTabItem}">
                <crud:BatchCrudControl/>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
