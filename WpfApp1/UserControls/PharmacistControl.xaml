<UserControl x:Class="PharmacyApp.Controls.PharmacistControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BrushBackground}">
    <TabControl Style="{StaticResource MainTabControl}" Margin="4">
        <!-- Приёмка -->
        <TabItem Header="📥 Приёмка" Style="{StaticResource InnerTabItem}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                <Border Style="{StaticResource CardBorder}" MaxWidth="560" HorizontalAlignment="Left">
                    <StackPanel>
                        <TextBlock Text="Приёмка товара" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="Номер накладной" Style="{StaticResource MutedCaption}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding InvoiceScanCode}" Margin="0,0,0,8"/>
                        <Button Content="Найти поставщика" Command="{Binding FindSupplierByInvoiceCommand}"
                                Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="Поставщик:" Style="{StaticResource MutedCaption}" Width="90"/>
                            <TextBlock Text="{Binding FoundSupplierName}" FontWeight="SemiBold"/>
                        </StackPanel>
                        <Button Content="Открыть окно приёмки партии" Command="{Binding SaveBatchAndItemsCommand}"
                                Style="{StaticResource AccentButton}" HorizontalContentAlignment="Left"/>
                    </StackPanel>
                </Border>
            </ScrollViewer>
        </TabItem>

        <!-- Склад -->
        <TabItem Header="🚚 Склад" Style="{StaticResource InnerTabItem}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                <StackPanel>
                    <Border Style="{StaticResource CardBorder}" MaxWidth="560" HorizontalAlignment="Left">
                        <StackPanel>
                            <TextBlock Text="Перемещение партии" Style="{StaticResource SectionTitle}"/>
                            <TextBlock Text="Партия" Style="{StaticResource MutedCaption}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding Batches}" DisplayMemberPath="SerialNumber"
                                      SelectedItem="{Binding SelectedBatch}" Margin="0,0,0,8"/>
                            <TextBlock Text="Новое место хранения" Style="{StaticResource MutedCaption}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NewStorageLocation}" Margin="0,0,0,12"/>
                            <Button Content="Переместить" Command="{Binding MoveBatchCommand}"
                                    Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorder}" MaxWidth="560" HorizontalAlignment="Left" Background="#FFFBEB">
                        <StackPanel>
                            <TextBlock Text="Условия хранения" Style="{StaticResource SectionTitle}"/>
                            <TextBlock Text="{Binding SelectedBatchStorageConditions}" TextWrapping="Wrap" Foreground="#92400E"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- Инвентаризация -->
        <TabItem Header="🔍 Инвентаризация" Style="{StaticResource InnerTabItem}">
            <Grid Margin="8">
                <Border Style="{StaticResource CardBorder}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Сверка остатков" Style="{StaticResource SectionTitle}"/>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding InventoryItems}" AutoGenerateColumns="False" MinHeight="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Товар" Binding="{Binding ItemName}" Width="*"/>
                                <DataGridTextColumn Header="Учёт" Binding="{Binding AccountQuantity}" Width="80"/>
                                <DataGridTextColumn Header="Факт" Binding="{Binding ActualQuantity, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Button Grid.Row="2" Content="Сравнить и скорректировать" Command="{Binding CompareAndCorrectCommand}"
                                Style="{StaticResource WarningButton}" HorizontalAlignment="Left" Margin="0,12,0,0"/>
                    </Grid>
                </Border>
            </Grid>
        </TabItem>

        <!-- Списание -->
        <TabItem Header="⏰ Списание" Style="{StaticResource InnerTabItem}">
            <Grid Margin="8">
                <Border Style="{StaticResource CardBorder}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Просроченные товары" Style="{StaticResource SectionTitle}"/>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding ExpiredBatches}" AutoGenerateColumns="False" MinHeight="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Товар" Binding="{Binding ItemName}" Width="*"/>
                                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="80"/>
                                <DataGridTextColumn Header="Убыток" Binding="{Binding LossAmount, StringFormat=C}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Button Grid.Row="2" Content="Создать документ списания" Command="{Binding CreateWriteOffDocCommand}"
                                Style="{StaticResource DangerButton}" HorizontalAlignment="Left" Margin="0,12,0,0"/>
                    </Grid>
                </Border>
            </Grid>
        </TabItem>
    </TabControl>
</UserControl>
