<UserControl x:Class="PharmacyApp.Controls.ManagerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BrushBackground}">
    <TabControl Style="{StaticResource MainTabControl}" Margin="4">
        <!-- Дашборд -->
        <TabItem Header="📊 Дашборд" Style="{StaticResource InnerTabItem}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                <StackPanel>
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="Показатели за вчера" Style="{StaticResource SectionTitle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource MetricCard}" Background="#E3F2FD">
                                    <StackPanel>
                                        <TextBlock Text="Выручка" Style="{StaticResource MutedCaption}"/>
                                        <TextBlock Text="{Binding YesterdayRevenue, StringFormat=C}" FontSize="24" FontWeight="Bold" Foreground="#1565C0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource MetricCard}" Background="#E8F5E9">
                                    <StackPanel>
                                        <TextBlock Text="Чеков" Style="{StaticResource MutedCaption}"/>
                                        <TextBlock Text="{Binding YesterdayReceiptCount}" FontSize="24" FontWeight="Bold" Foreground="#2E7D32"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Style="{StaticResource MetricCard}" Background="#FFF3E0">
                                    <StackPanel>
                                        <TextBlock Text="Средний чек" Style="{StaticResource MutedCaption}"/>
                                        <TextBlock Text="{Binding YesterdayAverageCheck, StringFormat=C}" FontSize="24" FontWeight="Bold" Foreground="#E65100"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <Button Content="Обновить данные" Command="{Binding RefreshDashboardCommand}"
                                    Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" Margin="4,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="Выручка за 7 дней" Style="{StaticResource SectionTitle}"/>
                            <Border Background="#F8FAFC" CornerRadius="8" Padding="16,8" MinHeight="140">
                                <ItemsControl ItemsSource="{Binding WeeklyRevenue}" VerticalAlignment="Bottom">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="8,0" VerticalAlignment="Bottom" Width="48">
                                                <Border Background="{StaticResource BrushPrimary}" CornerRadius="6,6,0,0"
                                                        Height="{Binding Value, Converter={StaticResource BarHeightConverter}}"
                                                        MinHeight="8" VerticalAlignment="Bottom"/>
                                                <TextBlock Text="{Binding Day}" HorizontalAlignment="Center" Margin="0,6,0,0"
                                                           FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- Отчёты -->
        <TabItem Header="📑 Отчёты" Style="{StaticResource InnerTabItem}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                <Border Style="{StaticResource CardBorder}" MaxWidth="520" HorizontalAlignment="Left">
                    <StackPanel>
                        <TextBlock Text="Отчёты и аналитика" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="Откройте детальные отчёты или экспортируйте данные" Style="{StaticResource MutedCaption}" Margin="0,0,0,16"/>
                        <Button Content="Топ категорий по выручке" Command="{Binding ShowCategoryRevenueCommand}"
                                Style="{StaticResource SecondaryButton}" Margin="0,0,0,8" HorizontalContentAlignment="Left"/>
                        <Button Content="Статистика по кассирам" Command="{Binding ShowCashierStatsCommand}"
                                Style="{StaticResource SecondaryButton}" Margin="0,0,0,8" HorizontalContentAlignment="Left"/>
                        <Button Content="Мониторинг дефектуры" Command="{Binding ShowDeficitReportCommand}"
                                Style="{StaticResource SecondaryButton}" Margin="0,0,0,8" HorizontalContentAlignment="Left"/>
                        <Button Content="Экспорт ежедневного отчёта (CSV)" Command="{Binding ExportDailyReportCommand}"
                                Style="{StaticResource PrimaryButton}" HorizontalContentAlignment="Left"/>
                    </StackPanel>
                </Border>
            </ScrollViewer>
        </TabItem>

        <!-- Цены -->
        <TabItem Header="💰 Цены" Style="{StaticResource InnerTabItem}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                <Border Style="{StaticResource CardBorder}" MaxWidth="520" HorizontalAlignment="Left">
                    <StackPanel>
                        <TextBlock Text="Цены и ценники" Style="{StaticResource SectionTitle}"/>
                        <Button Content="Массовое изменение цен" Command="{Binding BulkPriceChangeCommand}"
                                Style="{StaticResource PrimaryButton}" Margin="0,0,0,8" HorizontalContentAlignment="Left"/>
                        <Button Content="Печать ценников" Command="{Binding PrintPriceTagsCommand}"
                                Style="{StaticResource AccentButton}" Margin="0,0,0,8" HorizontalContentAlignment="Left"/>
                        <Button Content="Добавить пометку к категории" Command="{Binding AddCategoryNoteCommand}"
                                Style="{StaticResource SecondaryButton}" HorizontalContentAlignment="Left"/>
                    </StackPanel>
                </Border>
            </ScrollViewer>
        </TabItem>

        <!-- Заказы -->
        <TabItem Header="🛒 Заказы" Style="{StaticResource InnerTabItem}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                <Border Style="{StaticResource CardBorder}" MaxWidth="520" HorizontalAlignment="Left">
                    <StackPanel>
                        <TextBlock Text="Заказ поставщику" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="Сформируйте черновик заказа по товарам с дефицитом на складе"
                                   Style="{StaticResource MutedCaption}" TextWrapping="Wrap" Margin="0,0,0,16"/>
                        <Button Content="Создать черновик заказа" Command="{Binding CreateDraftOrderCommand}"
                                Style="{StaticResource AccentButton}" HorizontalContentAlignment="Left"/>
                    </StackPanel>
                </Border>
            </ScrollViewer>
        </TabItem>
    </TabControl>
</UserControl>
