<UserControl x:Class="PharmacyApp.Controls.CashierControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BrushBackground}">
    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель смены (всегда видна) -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,8">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Кассир:" Style="{StaticResource MutedCaption}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentUser}" FontWeight="SemiBold" Margin="6,0,16,0" VerticalAlignment="Center"/>
                    <Border Background="#E8F1FC" CornerRadius="12" Padding="10,4">
                        <TextBlock Text="{Binding ShiftStatusText}" Foreground="{StaticResource BrushPrimary}" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Открыть смену" Command="{Binding OpenShiftCommand}" Style="{StaticResource AccentButton}" Margin="0,0,8,0"/>
                    <Button Content="Закрыть смену" Command="{Binding CloseShiftCommand}" Style="{StaticResource DangerButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Style="{StaticResource MainTabControl}">
            <!-- Продажа -->
            <TabItem Header="🛒 Продажа" Style="{StaticResource InnerTabItem}">
                <Border Style="{StaticResource CardBorder}" Margin="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Текущая продажа" Style="{StaticResource SectionTitle}"/>
                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding Barcode, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Штрихкод + Enter">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding ScanBarcodeCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="1" Content="Добавить вручную" Command="{Binding AddItemManuallyCommand}"
                                    Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"/>
                        </Grid>
                        <CheckBox Grid.Row="2" Content="Рецепт проверен" IsChecked="{Binding PrescriptionVerified}"
                                  IsEnabled="{Binding IsPrescriptionRequired}" Margin="0,0,0,8"/>

                        <DataGrid Grid.Row="3" ItemsSource="{Binding Cart}" AutoGenerateColumns="False" MinHeight="180" Margin="0,4">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Товар" Binding="{Binding ItemName}" Width="*"/>
                                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="70"/>
                                <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat=C}" Width="90"/>
                                <DataGridTextColumn Header="Сумма" Binding="{Binding Total, StringFormat=C}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12">
                            <TextBlock Text="Итого:" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding CartTotal, StringFormat=C}" FontSize="26" FontWeight="Bold" Foreground="{StaticResource BrushPrimary}"/>
                        </StackPanel>

                        <UniformGrid Grid.Row="5" Columns="2" Margin="0,8,0,0">
                            <Button Content="Наличные" Command="{Binding PayCashCommand}" Style="{StaticResource AccentButton}" Margin="0,0,4,0"/>
                            <Button Content="Банковская карта" Command="{Binding PayCardCommand}" Style="{StaticResource PrimaryButton}" Margin="4,0,0,0"/>
                        </UniformGrid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- Возврат -->
            <TabItem Header="🔄 Возврат" Style="{StaticResource InnerTabItem}">
                <Border Style="{StaticResource CardBorder}" Margin="8">
                    <StackPanel>
                        <TextBlock Text="Оформление возврата" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="Введите номер чека и откройте окно возврата" Style="{StaticResource MutedCaption}" Margin="0,0,0,12"/>
                        <TextBox Text="{Binding ReturnReceiptNumber}" Margin="0,0,0,12"/>
                        <Button Content="Оформить возврат" Command="{Binding ProcessReturnCommand}"
                                Style="{StaticResource WarningButton}" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- Смена -->
            <TabItem Header="📋 Смена" Style="{StaticResource InnerTabItem}">
                <Border Style="{StaticResource CardBorder}" Margin="8" MaxWidth="400" HorizontalAlignment="Left">
                    <StackPanel>
                        <TextBlock Text="Итоги текущей смены" Style="{StaticResource SectionTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Начало" Style="{StaticResource MutedCaption}"/>
                            <TextBlock Grid.Column="1" Text="{Binding ShiftStartTime, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="1" Text="Продаж" Style="{StaticResource MutedCaption}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ShiftSalesCount}" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="2" Text="Наличные" Style="{StaticResource MutedCaption}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ShiftTotalCash, StringFormat=C}" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="3" Text="Карта" Style="{StaticResource MutedCaption}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ShiftTotalCard, StringFormat=C}" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="4" Text="Всего" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ShiftTotal, StringFormat=C}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource BrushPrimary}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
