<Window x:Class="PharmacyApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PharmacyApp.Controls"
        Title="Аптека" Height="700" Width="1050" MinHeight="560" MinWidth="880"
        Background="{StaticResource BrushBackground}"
        FontFamily="{StaticResource FontUi}"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource BrushPrimary}" Padding="16,12">
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Аптека" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock x:Name="TxtRoleHint" Text="Учёт товаров и продаж" FontSize="12" Foreground="#FFFFFFCC" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtCurrentUser" Text="Пользователь" Foreground="White" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Button x:Name="BtnLogout" Content="Выйти" Click="LogoutButton_Click"
                            Padding="14,6" Background="Transparent" Foreground="White" BorderBrush="#FFFFFF88" BorderThickness="1" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl x:Name="MainTabs" Grid.Row="1" Margin="10"
                    Style="{StaticResource MainTabControl}"
                    SelectionChanged="MainTabs_SelectionChanged">
            <TabItem x:Name="TabManager" Header="Менеджер" Style="{StaticResource MainTabItem}">
                <controls:ManagerControl/>
            </TabItem>
            <TabItem x:Name="TabPharmacist" Header="Провизор" Style="{StaticResource MainTabItem}">
                <controls:PharmacistControl/>
            </TabItem>
            <TabItem x:Name="TabCashier" Header="Кассир" Style="{StaticResource MainTabItem}">
                <controls:CashierControl/>
            </TabItem>
            <TabItem x:Name="TabCatalog" Header="Справочники" Style="{StaticResource MainTabItem}">
                <controls:EntityManagementControl/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
