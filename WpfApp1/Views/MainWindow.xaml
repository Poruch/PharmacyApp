<Window x:Class="PharmacyApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PharmacyApp.Views"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Вкладки для выбора роли (только для демо, реально выбор по авторизации) -->
        <TabControl Grid.Row="0" SelectionChanged="TabControl_SelectionChanged">
            <TabItem Header="Менеджер" Tag="Manager"/>
            <TabItem Header="Провизор" Tag="Pharmacist"/>
            <TabItem Header="Кассир" Tag="Cashier"/>
        </TabControl>

        <ContentControl x:Name="MainContent" Grid.Row="1" Margin="10"/>
    </Grid>
</Window>
