<Window x:Class="PharmacyApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PharmacyApp.Controls"
        Title="Аптека — система учёта" Height="720" Width="1100" MinHeight="600" MinWidth="900"
        Background="{StaticResource BrushBackground}"
        FontFamily="{StaticResource FontUi}"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Padding="20,14">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#2C7BE5" Offset="0"/>
                    <GradientStop Color="#1A5BB8" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="White" CornerRadius="8" Padding="10,6" Margin="0,0,14,0">
                        <TextBlock Text="💊" FontSize="22"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Аптека" FontSize="20" FontWeight="Bold" Foreground="White"/>
                        <TextBlock x:Name="TxtRoleHint" Text="Система учёта товаров и продаж" FontSize="12" Foreground="#FFFFFFCC"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border Background="Black" CornerRadius="20" Padding="12,6" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👤 " Foreground="White" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtCurrentUser" Text="Пользователь" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Button x:Name="BtnLogout" Content="Выйти" Click="LogoutButton_Click"
                            Style="{StaticResource OutlineButton}" Foreground="White" Padding="16,8">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="Black" CornerRadius="8" Padding="16,8" BorderBrush="#FFFFFF55" BorderThickness="1">
                                    <ContentPresenter HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#FFFFFF44"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основные вкладки по ролям -->
        <TabControl x:Name="MainTabs" Grid.Row="1" Margin="12,8,12,12"
                    Style="{StaticResource MainTabControl}"
                    SelectionChanged="MainTabs_SelectionChanged">
            <TabItem x:Name="TabManager" Header="Менеджер" Tag="Manager" Style="{StaticResource MainTabItem}">
                <controls:ManagerControl/>
            </TabItem>
            <TabItem x:Name="TabPharmacist" Header="Провизор" Tag="Pharmacist" Style="{StaticResource MainTabItem}">
                <controls:PharmacistControl/>
            </TabItem>
            <TabItem x:Name="TabCashier" Header="Кассир" Tag="Cashier" Style="{StaticResource MainTabItem}">
                <controls:CashierControl/>
            </TabItem>
            <TabItem x:Name="TabCatalog" Header="Справочники" Tag="Catalog" Style="{StaticResource MainTabItem}">
                <controls:EntityManagementControl/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
