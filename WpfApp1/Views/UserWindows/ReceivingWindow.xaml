<Window x:Class="PharmacyApp.Views.ReceivingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Приёмка партии товара" Height="700" Width="800"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. Сканирование накладной -->
        <TextBlock Text="1. Сканируйте накладную (или введите номер)" FontWeight="SemiBold" Margin="0,0,0,5"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox Text="{Binding InvoiceNumber, UpdateSourceTrigger=PropertyChanged}" Width="300" Margin="0,0,10,0"/>
            <Button Content="Найти поставщика" Command="{Binding FindSupplierCommand}" Width="150"/>
        </StackPanel>
        <TextBlock Grid.Row="2" Text="{Binding SupplierInfo}" Margin="0,0,0,10" FontWeight="Bold" Foreground="DarkGreen"/>

        <!-- 2. Выбор товара (немарочный / маркировка) -->
        <TextBlock Grid.Row="3" Text="2. Выберите товар" FontWeight="SemiBold" Margin="0,0,0,5"/>
        <ComboBox Grid.Row="4" ItemsSource="{Binding AvailableItems}" DisplayMemberPath="Name" 
                  SelectedItem="{Binding SelectedItem}" Margin="0,0,0,10" Height="30"/>

        <!-- 3. Сканирование кодов DataMatrix (для маркированных) -->
        <TextBlock Grid.Row="5" Text="3. Сканируйте коды DataMatrix (по одному)" FontWeight="SemiBold" Margin="0,0,0,5"/>
        <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,0,0,5">
            <TextBox Text="{Binding ScannedCode, UpdateSourceTrigger=PropertyChanged}" Width="300" Margin="0,0,10,0"/>
            <Button Content="Добавить код" Command="{Binding AddCodeCommand}" Width="120"/>
            <Button Content="Очистить список" Command="{Binding ClearCodesCommand}" Width="120" Margin="10,0,0,0"/>
        </StackPanel>
        <ListBox Grid.Row="7" ItemsSource="{Binding ScannedCodes}" Height="100" Margin="0,0,0,10"/>

        <!-- 4. Данные партии -->
        <Grid Grid.Row="8" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Номер партии (серия):" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding BatchNumber}" Width="200" Margin="0,0,10,5"/>

            <TextBlock Grid.Row="0" Grid.Column="2" Text="Срок годности:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <DatePicker Grid.Row="0" Grid.Column="3" SelectedDate="{Binding ExpiryDate}" Width="150" Margin="0,0,0,5"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Закупочная цена:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding PurchasePrice}" Width="200" Margin="0,0,10,5"/>

            <TextBlock Grid.Row="1" Grid.Column="2" Text="Розничная цена:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding RetailPrice}" Width="150" Margin="0,0,0,5"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Место хранения:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding StorageLocation}" Width="200" Margin="0,0,10,5"/>

            <TextBlock Grid.Row="2" Grid.Column="2" Text="Количество упаковок:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding Quantity}" Width="150" Margin="0,0,0,5"/>
        </Grid>

        <!-- 5. Сохранение -->
        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Сохранить партию и экземпляры" Command="{Binding SaveBatchCommand}" 
                    Width="220" Margin="0,0,10,0" Background="#28A745" Foreground="White"/>
            <Button Content="Отмена" Command="{Binding CancelCommand}" Width="100"/>
        </StackPanel>
    </Grid>
</Window>