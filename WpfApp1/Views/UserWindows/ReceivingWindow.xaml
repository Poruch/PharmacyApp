<Window x:Class="PharmacyApp.Views.ReceivingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Приёмка партии товара" Height="720" Width="820"
        WindowStartupLocation="CenterOwner" MinHeight="600" MinWidth="700">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="1. Сканируйте накладную (или введите номер)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBox Text="{Binding InvoiceNumber, UpdateSourceTrigger=PropertyChanged}" Width="300" Margin="0,0,10,0"/>
                    <Button Content="Найти поставщика" Command="{Binding FindSupplierCommand}" Width="150"/>
                </StackPanel>
                <TextBlock Grid.Row="2" Text="{Binding SupplierInfo}" Margin="0,0,0,10" FontWeight="Bold" Foreground="DarkGreen"/>

                <TextBlock Grid.Row="3" Text="2. Выберите товар" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox Grid.Row="4" ItemsSource="{Binding AvailableItems}" DisplayMemberPath="Name"
                          SelectedItem="{Binding SelectedItem}" Margin="0,0,0,10" Height="30"/>

                <TextBlock Grid.Row="5" Text="3. Сканируйте коды DataMatrix (по одному)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBox Text="{Binding ScannedCode, UpdateSourceTrigger=PropertyChanged}" Width="300" Margin="0,0,10,0"/>
                    <Button Content="Добавить код" Command="{Binding AddCodeCommand}" Width="120"/>
                    <Button Content="Очистить список" Command="{Binding ClearCodesCommand}" Width="120" Margin="10,0,0,0"/>
                </StackPanel>
                <ListBox Grid.Row="7" ItemsSource="{Binding ScannedCodes}" MaxHeight="120" MinHeight="60" Margin="0,0,0,10"/>

                <TextBlock Grid.Row="8" Text="4. Данные партии" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Grid Grid.Row="9" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Номер партии (серия):" VerticalAlignment="Center" Margin="0,0,10,8"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding BatchNumber}" Margin="0,0,16,8"/>

                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Срок годности:" VerticalAlignment="Center" Margin="0,0,10,8"/>
                    <DatePicker Grid.Row="0" Grid.Column="3" SelectedDate="{Binding ExpiryDate}" Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Закупочная цена:" VerticalAlignment="Center" Margin="0,0,10,8"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding PurchasePrice}" Margin="0,0,16,8"/>

                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Розничная цена:" VerticalAlignment="Center" Margin="0,0,10,8"/>
                    <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding RetailPrice}" Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Место хранения:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding StorageLocations}"
                              DisplayMemberPath="DisplayName" SelectedItem="{Binding SelectedStorageLocation}"
                              Margin="0,0,16,0"/>

                    <TextBlock Grid.Row="2" Grid.Column="2" Text="Количество упаковок:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding Quantity}"/>
                </Grid>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Сохранить партию и экземпляры" Command="{Binding SaveBatchCommand}"
                    MinWidth="220" Margin="0,0,10,0" Padding="12,8"
                    Background="#28A745" Foreground="White"/>
            <Button Content="Отмена" Command="{Binding CancelCommand}" MinWidth="100" Padding="12,8"/>
        </StackPanel>
    </Grid>
</Window>
