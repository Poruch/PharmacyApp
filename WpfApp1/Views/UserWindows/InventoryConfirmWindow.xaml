<Window x:Class="PharmacyApp.Views.InventoryConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Подтверждение инвентаризации" Height="500" Width="780"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Будут скорректированы остатки по следующим партиям:"
                   FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,12"/>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Changes}" AutoGenerateColumns="False"
                  IsReadOnly="True" CanUserAddRows="False" MinHeight="260">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Товар" Binding="{Binding ItemName}" Width="*"/>
                <DataGridTextColumn Header="Серия" Binding="{Binding BatchNumber}" Width="80"/>
                <DataGridTextColumn Header="Место" Binding="{Binding StorageLocationName}" Width="100"/>
                <DataGridTextColumn Header="Срок годности" Binding="{Binding ExpiryDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Учёт" Binding="{Binding AccountQuantity}" Width="60"/>
                <DataGridTextColumn Header="Факт" Binding="{Binding ActualQuantity}" Width="60"/>
                <DataGridTextColumn Header="Изменение" Binding="{Binding ChangeDescription}" Width="110"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Подтвердить" IsDefault="True" MinWidth="120" Margin="0,0,10,0"
                    Padding="12,8" Click="Confirm_Click"/>
            <Button Content="Отмена" IsCancel="True" MinWidth="100" Padding="12,8" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
