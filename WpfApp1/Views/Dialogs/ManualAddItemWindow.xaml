<Window x:Class="PharmacyApp.Views.ManualAddItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить товар вручную" Height="320" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Выберите товар из списка и укажите количество" FontWeight="SemiBold" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="1" Text="Товар:" Margin="0,0,0,5"/>
        <ComboBox Grid.Row="2" ItemsSource="{Binding Items}" DisplayMemberPath="Name"
                  SelectedItem="{Binding BoundSelectedItem}" Height="32" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="3" Text="Количество:" Margin="0,0,0,5"/>
        <TextBox Grid.Row="4" Text="{Binding QuantityText, UpdateSourceTrigger=PropertyChanged}"
                 Height="32" VerticalAlignment="Top" Padding="8" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Добавить" Command="{Binding AddCommand}" Width="110" Margin="0,0,10,0"
                    Background="#28A745" Foreground="White" Padding="8,6"/>
            <Button Content="Отмена" Command="{Binding CancelCommand}" Width="100" Padding="8,6"/>
        </StackPanel>
    </Grid>
</Window>
