<Window x:Class="PharmacyApp.Views.ReturnWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Оформление возврата товара" Height="550" Width="750"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Введите номер чека для возврата" FontWeight="SemiBold" Margin="0,0,0,5"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBox Text="{Binding ReceiptNumber, UpdateSourceTrigger=PropertyChanged}" Width="200" Margin="0,0,10,0"/>
            <Button Content="Загрузить продажу" Command="{Binding LoadSaleCommand}" Width="150"/>
        </StackPanel>

        <Border Grid.Row="2" Background="#F0F0F0" Padding="10" CornerRadius="5" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="{Binding SaleInfo}" FontWeight="Bold"/>
                <TextBlock Text="{Binding SaleDate}" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="3" ItemsSource="{Binding SaleItems}" AutoGenerateColumns="False" 
                  CanUserAddRows="False" Margin="0,0,0,15">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Товар" Binding="{Binding ItemName}" Width="*"/>
                <DataGridTextColumn Header="Кол-во в чеке" Binding="{Binding Quantity}" Width="100"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat=C}" Width="100"/>
                <DataGridTemplateColumn Header="Возвращаемое кол-во" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding ReturnQuantity, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Сумма возврата" Binding="{Binding ReturnSum, StringFormat=C}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBox Text="{Binding ReturnReason}" Width="200" Margin="0,0,10,0" Tag="Причина возврата"/>
            <Button Content="Оформить возврат" Command="{Binding ProcessReturnCommand}" 
                    Width="150" Margin="0,0,10,0" Background="#FD7E14" Foreground="White"/>
            <Button Content="Отмена" Command="{Binding CancelCommand}" Width="100"/>
        </StackPanel>
    </Grid>
</Window>