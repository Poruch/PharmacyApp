<Application x:Class="PharmacyApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PharmacyApp"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/PharmacyTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:BarHeightConverter x:Key="BarHeightConverter" xmlns:converters="clr-namespace:PharmacyApp.Converters"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
